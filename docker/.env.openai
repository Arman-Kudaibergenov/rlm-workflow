# External OpenAI-compatible embedding — no local model loaded
RLM_TRANSPORT=streamable-http
RLM_EMBEDDING_PROVIDER=openai
RLM_EMBEDDING_MODEL=text-embedding-3-small
RLM_EMBEDDING_STRICT=true
OPENAI_API_KEY=your-key-here
# For LM Studio: OPENAI_API_BASE=http://localhost:1234/v1
# For OpenRouter: OPENAI_API_BASE=https://openrouter.ai/api/v1
