# RLM Server Configuration
RLM_PORT=8200

# Embedding model: any sentence-transformers compatible model from HuggingFace
# Default: paraphrase-multilingual-MiniLM-L12-v2 (Russian, English, 50+ languages, CPU-only, ~471MB)
# Original rlm-toolkit default (if unset): all-MiniLM-L6-v2 (English only)
RLM_EMBEDDING_MODEL=paraphrase-multilingual-MiniLM-L12-v2

# Other sentence-transformers models you can use:
# RLM_EMBEDDING_MODEL=all-MiniLM-L6-v2                          # English, fast, 384d
# RLM_EMBEDDING_MODEL=paraphrase-multilingual-mpnet-base-v2     # 50+ languages, 768d
# RLM_EMBEDDING_MODEL=all-mpnet-base-v2                         # English, high quality, 768d

# OpenAI API key (for rlm-toolkit LLM features, NOT for embeddings)
# OPENAI_API_KEY=sk-...

# Project root for file discovery (optional, defaults to /data)
# RLM_PROJECT_ROOT=/workspace
