# RLM Server Configuration
RLM_PORT=8200

# Embedding provider: fastembed | openai | ollama
RLM_EMBEDDING_PROVIDER=fastembed

# OpenAI (if using openai provider)
# OPENAI_API_KEY=sk-...
# RLM_EMBEDDING_MODEL=text-embedding-3-small

# Ollama (if using ollama provider)
# OLLAMA_BASE_URL=http://host.docker.internal:11434
# RLM_EMBEDDING_MODEL=nomic-embed-text
