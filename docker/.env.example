# RLM Server Configuration
RLM_PORT=8200
RLM_TRANSPORT=streamable-http

# --- Deployment Profiles ---
# Three ready-made .env files are provided:
#   .env.cpu     — built-in CPU embedding (default, no dependencies)
#   .env.ollama  — external Ollama embedding (GPU-accelerated)
#   .env.openai  — external OpenAI-compatible embedding (LM Studio, OpenRouter, etc.)
#
# Usage: docker compose --env-file .env.cpu up

# --- Embedding Configuration ---

# Provider: sentence-transformers (default) or ollama or openai
# RLM_EMBEDDING_PROVIDER=ollama

# Model name:
# - For sentence-transformers: any HuggingFace model (e.g., paraphrase-multilingual-MiniLM-L12-v2)
# - For ollama: any model with embedding support (e.g., qwen3-embedding:8b)
# - For openai: text-embedding-3-small, text-embedding-3-large, etc.
RLM_EMBEDDING_MODEL=paraphrase-multilingual-MiniLM-L12-v2

# Strict mode: if true, fail on embedding error instead of falling back to local model.
# Recommended when using external providers to avoid loading ~471MB local model.
# RLM_EMBEDDING_STRICT=true

# --- Ollama settings (only when RLM_EMBEDDING_PROVIDER=ollama) ---
# OLLAMA_BASE_URL=http://host.docker.internal:11434
# RLM_EMBEDDING_MODEL=qwen3-embedding:8b

# --- OpenAI settings (only when RLM_EMBEDDING_PROVIDER=openai) ---
# OPENAI_API_KEY=sk-...
# RLM_EMBEDDING_MODEL=text-embedding-3-small    # 1536d, cheapest
# RLM_EMBEDDING_MODEL=text-embedding-3-large    # 3072d, best quality
# RLM_EMBEDDING_MODEL=text-embedding-ada-002    # 1536d, legacy
# For LM Studio: OPENAI_API_BASE=http://localhost:1234/v1
# For OpenRouter: OPENAI_API_BASE=https://openrouter.ai/api/v1

# --- Sentence-transformers models (default provider) ---
# RLM_EMBEDDING_MODEL=all-MiniLM-L6-v2                          # English, fast, 384d
# RLM_EMBEDDING_MODEL=paraphrase-multilingual-MiniLM-L12-v2     # 50+ languages, 384d
# RLM_EMBEDDING_MODEL=paraphrase-multilingual-mpnet-base-v2     # 50+ languages, 768d

# Project root for file discovery (optional, defaults to /data)
# RLM_PROJECT_ROOT=/workspace
